<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ description or site.description }}" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=Rajdhani:wght@400;500;600&family=Noto+Sans+JP:wght@300&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=Rajdhani:wght@400;500;600&family=Noto+Sans+JP:wght@300&display=swap" /></noscript>
  <script src="/js/search.js" defer></script>
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="/" class="site-title">{{ site.title }}</a>
      <div class="site-header-search">
        <button class="search-toggle" id="search-toggle" aria-label="Open search" aria-expanded="false">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </button>
        <input id="search-input" type="search" placeholder="Search…" autocomplete="off" aria-label="Search posts" />
        <button class="search-close" id="search-close" aria-label="Close search">Cancel</button>
      </div>
      <nav class="site-nav">
        {% for item in site.nav %}
          <a href="{{ item.url }}" {% if page.url == item.url %}class="active"{% endif %}>{{ item.label }}</a>
        {% endfor %}
      </nav>
    </div>
  </header>

  <main class="site-main">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="container">
      <nav class="footer-nav">
        {% for item in site.nav %}
          {% if item.url != "/" %}
            <a href="{{ item.url }}">{{ item.label }}</a>
          {% endif %}
        {% endfor %}
      </nav>
      <p class="footer-copy">{{ site.title }}</p>
    </div>
  </footer>
  <script>
    (function () {
      var toggle = document.getElementById('search-toggle');
      var close  = document.getElementById('search-close');
      var header = document.querySelector('.site-header');
      var input  = document.getElementById('search-input');

      window.closeSearch = function (clearInput) {
        header.classList.remove('search-open');
        document.body.classList.remove('search-open');
        if (toggle) toggle.setAttribute('aria-expanded', 'false');
        if (clearInput) {
          input.value = '';
          input.dispatchEvent(new Event('input'));
        }
      };

      if (toggle) toggle.addEventListener('click', function () {
        header.classList.add('search-open');
        document.body.classList.add('search-open');
        toggle.setAttribute('aria-expanded', 'true');
        input.focus();
      });
      if (close) close.addEventListener('click', function () {
        window.closeSearch(true);
      });
    })();
  </script>
</body>
</html>
